SECRET_KEY=change-me-in-production

# ============================================================================
# Database Configuration
# ============================================================================
# 
# DEVELOPMENT (SQLite - Default):
#   DATABASE_URL=sqlite:///placement_db_sqlite3.db
#
# PRODUCTION (MySQL via pymysql - Recommended):
#   DATABASE_URL=mysql+pymysql://username:password@localhost:3306/placement_db
#
# For remote MySQL servers:
#   DATABASE_URL=mysql+pymysql://username:password@your.db.host:3306/placement_db
#
# MySQL Setup Instructions:
#   1. Create database:
#      mysql -u root -p
#      > CREATE DATABASE placement_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   
#   2. Create user with privileges:
#      > CREATE USER 'placement_user'@'localhost' IDENTIFIED BY 'strong_password';
#      > GRANT ALL PRIVILEGES ON placement_db.* TO 'placement_user'@'localhost';
#      > FLUSH PRIVILEGES;
#   
#   3. Set DATABASE_URL to:
#      mysql+pymysql://placement_user:strong_password@localhost:3306/placement_db
#
DATABASE_URL=sqlite:///placement_db_sqlite3.db
FLASK_DEBUG=1
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=1
MAIL_USE_SSL=0
MAIL_DEFAULT_SENDER=placement-cell@example.com
MAIL_SUPPRESS_SEND=0
COLLEGE_NAME=CEC Placement Administration
